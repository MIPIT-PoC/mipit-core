# E2E Test Environment
NODE_ENV=test
LOG_LEVEL=error

# API
API_HOST=localhost
PORT=8080

# Database — docker postgres exposed on 5433 to avoid host postgres clash;
# we run the suite against the live `mipit` DB (PoC, no separate test DB).
DATABASE_URL=postgresql://mipit:mipit_secret@localhost:5433/mipit

# RabbitMQ
RABBITMQ_URL=amqp://mipit:mipit_secret@localhost:5672/mipit

# External APIs (adapters)
PIX_SPI_URL=http://localhost:8001
SPEI_CECOBAN_URL=http://localhost:8002

# OAuth
PIX_CLIENT_ID=mipit-test
PIX_CLIENT_SECRET=test-secret-pix
SPEI_CLIENT_ID=mipit-test
SPEI_CLIENT_SECRET=test-secret-spei

# Testing
TEST_TIMEOUT=30000
WAIT_FOR_MESSAGE_TIMEOUT=5000
