VALIDATION_MODE=deployment

# API target
API_PROTOCOL=https
API_HOST=10.43.101.28
PORT=443
API_TOKEN_PATH=/auth/token
ALLOW_INVALID_CERTS=true

# Async polling behavior
ASYNC_POLL_TIMEOUT_MS=15000
ASYNC_POLL_INTERVAL_MS=1000
ALLOW_INTERMEDIATE_ASYNC_STATES=true

# Optional infrastructure checks
DATABASE_URL=postgresql://mipit:mipit_secret@localhost:5432/mipit
RABBITMQ_URL=amqp://mipit:mipit_secret@localhost:5672/mipit

# Optional remote mock checks
PIX_MOCK_URL=http://10.43.101.29:9001
SPEI_MOCK_URL=http://10.43.101.29:9002
BREB_MOCK_URL=http://10.43.101.29:9003

# Artifacts
OUTPUT_DIR=./test/validation/results
